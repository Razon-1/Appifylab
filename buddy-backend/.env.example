# Environment Configuration Template
# Copy this file to .env and fill in your values

# ========== DJANGO CONFIGURATION ==========
# Security key for Django (generate a new one for production!)
SECRET_KEY=django-insecure-buddy-script-dev-key-change-in-production

# Debug mode (set to False in production)
DEBUG=True

# Allowed hosts for the application
ALLOWED_HOSTS=localhost,127.0.0.1,localhost:8000

# ========== DATABASE CONFIGURATION ==========
# Database engine (use django.db.backends.mysql for MySQL)
DB_ENGINE=django.db.backends.mysql

# Database name
DB_NAME=appifylab

# Database user
DB_USER=root

# Database password (leave empty if no password)
DB_PASSWORD=

# Database host
DB_HOST=localhost

# Database port (3306 for MySQL)
DB_PORT=3306

# ========== CORS CONFIGURATION ==========
# Frontend URL for CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ========== OPTIONAL: EMAIL CONFIGURATION ==========
# For future email verification and password reset features
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# ========== OPTIONAL: AWS S3 CONFIGURATION ==========
# For production image storage
# AWS_ACCESS_KEY_ID=your-key-id
# AWS_SECRET_ACCESS_KEY=your-secret-key
# AWS_STORAGE_BUCKET_NAME=buddy-script-media
# AWS_S3_REGION_NAME=us-east-1

# ========== OPTIONAL: REDIS CONFIGURATION ==========
# For caching and celery (future)
# REDIS_URL=redis://localhost:6379/0
