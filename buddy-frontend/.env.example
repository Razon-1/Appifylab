# Frontend Environment Configuration
# Copy this file to .env and customize for your environment

# ========== API CONFIGURATION ==========
# Backend API URL
REACT_APP_API_URL=http://localhost:8000/api

# ========== APP CONFIGURATION ==========
# Application name
REACT_APP_APP_NAME=Buddy Script

# Application version
REACT_APP_VERSION=1.0.0

# ========== FEATURE FLAGS ==========
# Enable dark mode toggle
REACT_APP_ENABLE_DARK_MODE=true

# Enable push notifications
REACT_APP_ENABLE_NOTIFICATIONS=false

# Enable image uploads
REACT_APP_ENABLE_IMAGE_UPLOAD=false

# ========== OPTIONAL: ANALYTICS ==========
# Google Analytics ID (if using)
# REACT_APP_GOOGLE_ANALYTICS_ID=your-id-here

# ========== OPTIONAL: EXTERNAL SERVICES ==========
# AWS API Keys (if using)
# REACT_APP_AWS_API_KEY=your-key-here

# Stripe API Key (if using payments)
# REACT_APP_STRIPE_PUBLIC_KEY=your-key-here
